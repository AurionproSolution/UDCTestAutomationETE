{
    "$schema": "https://specflow.org/specflow-config.json",
    "bindingCulture": {
        "language": "en-us"
    },
    "language": {
        "feature": "en-us"
    },
    "unitTestProvider": {
        "name": "NUnit"
    },
    "stepAssemblies": [
        {
            "assembly": "Navistar"
        }
    ],
    "trace": {
        "traceSuccessfulSteps": true,
        "traceTimings": true,
        "minTracedDuration": "0:00:00.1"
    }
}
