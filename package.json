{
  "name": "udc-automation-tests",
  "version": "1.0.0",
  "description": "UDC Automation Tests - Playwright TypeScript Framework for DO, RSS, and CSS Portals",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:ui": "npx playwright test --ui",
    "test:debug": "npx playwright test --debug",
    "test:do": "npx playwright test --project=do-portal-chromium",
    "test:do:sanity": "npx playwright test tests/do-portal/doSanityTest --project=do-sanity-chromium",
    "test:do:firefox": "npx playwright test --project=do-portal-firefox",
    "test:do:webkit": "npx playwright test --project=do-portal-webkit",
    "test:rss": "npx playwright test --project=rss-portal-chromium",
    "test:rss:firefox": "npx playwright test --project=rss-portal-firefox",
    "test:css": "npx playwright test --project=css-portal-chromium",
    "test:css:firefox": "npx playwright test --project=css-portal-firefox",
    "test:smoke": "npx playwright test --project=all-portals-smoke",
    "test:regression": "npx playwright test --project=all-portals-regression",
    "test:mobile": "npx playwright test --project=mobile-chrome --project=mobile-safari",
    "test:all-portals": "npx playwright test --project=do-portal-chromium --project=rss-portal-chromium --project=css-portal-chromium",
    "test:env:dev": "cross-env TEST_ENV=dev npx playwright test",
    "test:env:qat": "cross-env TEST_ENV=qat npx playwright test",
    "test:env:uat": "cross-env TEST_ENV=uat npx playwright test",
    "test:env:prod": "cross-env TEST_ENV=prod npx playwright test",
    "report": "npx playwright show-report my-report",
    "report:ortoni": "npx playwright show-report ortoni-report",
    "lint": "tsc --noEmit",
    "clean": "rimraf test-results my-report ortoni-report"
  },
  "keywords": [
    "playwright",
    "typescript",
    "automation",
    "testing",
    "e2e",
    "udc",
    "do-portal",
    "rss-portal",
    "css-portal"
  ],
  "author": "UDC Team",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.41.0",
    "@types/node": "^20.11.0",
    "cross-env": "^7.0.3",
    "ortoni-report": "^4.0.8",
    "rimraf": "^5.0.5",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "dotenv": "^16.3.1"
  }
}
